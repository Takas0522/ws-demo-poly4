# Application Settings
APP_NAME="Service Setting Service"
APP_VERSION="0.1.0"
APP_ENV="development"

# Server Configuration
HOST="0.0.0.0"
PORT=8004

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# Cosmos DB Configuration
COSMOSDB_ENDPOINT="https://your-account.documents.azure.com:443/"
COSMOSDB_KEY="your-cosmos-db-key-here"
COSMOSDB_DATABASE="management-app"

# Container Names
COSMOSDB_SERVICES_CONTAINER="services"
COSMOSDB_SERVICE_ASSIGNMENTS_CONTAINER="service-assignments"

# Auth Service Configuration (for JWT verification)
AUTH_SERVICE_URL="http://localhost:8003"
AUTH_SERVICE_PUBLIC_KEY_ENDPOINT="/api/auth/public-key"

# JWT Configuration
JWT_ALGORITHM="RS256"
JWT_AUDIENCE="management-app"
JWT_ISSUER="auth-service"

# Logging Configuration
LOG_LEVEL="INFO"
LOG_FORMAT="json"
