# Test environment configuration
APP_NAME="Service Setting Service"
APP_VERSION="0.1.0"
APP_ENV="test"

# Cosmos DB Configuration (mock values for testing)
COSMOSDB_ENDPOINT="https://test-account.documents.azure.com:443/"
COSMOSDB_KEY="test-key-for-unit-tests"
COSMOSDB_DATABASE="management-app"
COSMOSDB_SERVICES_CONTAINER="services"
COSMOSDB_SERVICE_ASSIGNMENTS_CONTAINER="service-assignments"

# Auth Service Configuration
AUTH_SERVICE_URL="http://localhost:8003"
AUTH_SERVICE_PUBLIC_KEY_ENDPOINT="/api/auth/public-key"

# JWT Configuration
JWT_ALGORITHM="RS256"
JWT_AUDIENCE="management-app"
JWT_ISSUER="auth-service"

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="json"
